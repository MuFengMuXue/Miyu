#!/usr/bin/env bash
# 描述：列出给定软件的环境变量。支持命令行参数或 JSON stdin。
# description: Show environment variables for an application. Supports argv or JSON stdin.

set -u

APP_NAME="showenv"

usage() {
  cat <<'EOF'
showenv - show environment variables for an application process

Usage:
  showenv <app-name|pid>
  showenv --pid <pid>
  echo '{"app":"qq"}' | showenv
  echo '{"pid":12345}' | showenv

Examples:
  showenv firefox
  showenv code
  showenv qq
  showenv --pid 12345

Process selection uses fast exact matches first:
  1. desktop id, command name, and wrapper target
  2. process comm / argv0 exact matches
  3. desktop Name / StartupWMClass fallback

This avoids matching names like opencode for code or linuxqq-clipsync for qq.
EOF
}

err() { printf 'error: %s\n' "$*" >&2; }
die() { err "$*"; exit 1; }

is_pid() {
  [[ "${1:-}" =~ ^[0-9]+$ ]]
}

json_string_value() {
  local input="$1" key="$2" pattern
  pattern="\"$key\"[[:space:]]*:[[:space:]]*\"([^\"]*)\""
  [[ "$input" =~ $pattern ]] && printf '%s' "${BASH_REMATCH[1]}"
}

json_number_value() {
  local input="$1" key="$2" pattern
  pattern="\"$key\"[[:space:]]*:[[:space:]]*([0-9]+)"
  [[ "$input" =~ $pattern ]] && printf '%s' "${BASH_REMATCH[1]}"
}

json_first_arg() {
  local input="$1" pattern
  pattern='"args"[[:space:]]*:[[:space:]]*\[[[:space:]]*"([^"]*)"'
  [[ "$input" =~ $pattern ]] && printf '%s' "${BASH_REMATCH[1]}"
}

target_from_input() {
  local input="$1" value key
  input="$(trim "$input")"
  [[ -n "$input" ]] || return 1

  value="$(json_number_value "$input" pid)"
  [[ -n "$value" ]] && { printf '%s' "$value"; return 0; }

  for key in app app_name appName application name software program process process_name processName query target command; do
    value="$(json_string_value "$input" "$key")"
    [[ -n "$value" ]] && { printf '%s' "$value"; return 0; }
  done

  value="$(json_first_arg "$input")"
  [[ -n "$value" ]] && { printf '%s' "$value"; return 0; }

  if [[ "$input" != *'{'* && "$input" != *'['* && "$input" != *':'* ]]; then
    printf '%s' "$input"
    return 0
  fi

  return 1
}

lower() {
  printf '%s' "${1,,}"
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

strip_quotes() {
  local value="$1"
  if [[ "$value" == '"'*'"' && ${#value} -ge 2 ]]; then
    value="${value:1:${#value}-2}"
  elif [[ "$value" == "'"*"'" && ${#value} -ge 2 ]]; then
    value="${value:1:${#value}-2}"
  fi
  printf '%s' "$value"
}

same_token() {
  [[ "${1,,}" == "${2,,}" ]]
}

contains_token() {
  [[ "${1,,}" == *"${2,,}"* ]]
}

desktop_dirs() {
  printf '%s\n' \
    "$HOME/.local/share/applications" \
    "$HOME/.local/share/flatpak/exports/share/applications" \
    "/usr/local/share/applications" \
    "/usr/share/applications" \
    "/var/lib/flatpak/exports/share/applications"
}

desktop_id() {
  local path="${1##*/}"
  printf '%s' "${path%.desktop}"
}

read_comm() {
  local pid="$1" value
  [[ -r "/proc/$pid/comm" ]] || return 1
  IFS= read -r value < "/proc/$pid/comm" || return 1
  printf '%s' "$value"
}

read_ppid() {
  local pid="$1" key value
  [[ -r "/proc/$pid/status" ]] || return 1
  while IFS=$'\t ' read -r key value _; do
    [[ "$key" == "PPid:" ]] || continue
    printf '%s' "$value"
    return 0
  done < "/proc/$pid/status"
  return 1
}

read_argv0() {
  local pid="$1" arg0
  [[ -r "/proc/$pid/cmdline" ]] || return 1
  IFS= read -r -d '' arg0 < "/proc/$pid/cmdline" || [[ -n "${arg0:-}" ]] || return 1
  printf '%s' "${arg0##*/}"
}

read_cmdline() {
  local pid="$1" arg first=1
  [[ -r "/proc/$pid/cmdline" ]] || return 1
  while IFS= read -r -d '' arg; do
    if (( first )); then
      printf '%s' "$arg"
      first=0
    else
      printf ' %s' "$arg"
    fi
  done < "/proc/$pid/cmdline"
}

read_exe_path() {
  readlink -f "/proc/$1/exe" 2>/dev/null
}

first_exec_word() {
  local exec_line="$1" token
  exec_line="${exec_line//%[fFuUdDnNickvm]/}"
  exec_line="$(trim "$exec_line")"
  [[ -n "$exec_line" ]] || return 1

  if [[ "$exec_line" == '"'* ]]; then
    token="${exec_line#\"}"
    token="${token%%\"*}"
  elif [[ "$exec_line" == "'"* ]]; then
    token="${exec_line#\'}"
    token="${token%%\'*}"
  else
    token="${exec_line%%[[:space:]]*}"
  fi

  token="$(strip_quotes "$token")"
  [[ -n "$token" ]] || return 1
  printf '%s' "$token"
}

resolve_exec_path() {
  local exec_word="$1" resolved
  if [[ "$exec_word" == */* ]]; then
    readlink -f "$exec_word" 2>/dev/null || printf '%s' "$exec_word"
    return 0
  fi

  if resolved="$(command -v -- "$exec_word" 2>/dev/null)"; then
    readlink -f "$resolved" 2>/dev/null || printf '%s' "$resolved"
    return 0
  fi

  printf '%s' "$exec_word"
}

resolve_wrapper_exec_path() {
  local path="$1" line token
  [[ -r "$path" && -f "$path" ]] || return 1
  IFS= read -r line < "$path" || return 1
  [[ "$line" == '#!'* ]] || return 1

  while IFS= read -r line; do
    line="$(trim "$line")"
    [[ "$line" == exec[[:space:]]/* ]] || continue
    token="${line#exec }"
    token="${token%%[[:space:]]*}"
    token="$(strip_quotes "$token")"
    [[ -n "$token" ]] || continue
    resolve_exec_path "$token"
    return 0
  done < "$path"

  return 1
}

parse_desktop() {
  local file="$1" line key value name="" name_l10n="" exec_line="" tryexec="" wmclass=""
  [[ -r "$file" ]] || return 1

  while IFS= read -r line; do
    [[ "$line" == *=* ]] || continue
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      Name) [[ -z "$name" ]] && name="$value" ;;
      Name\[*\]) [[ -z "$name_l10n" ]] && name_l10n="$value" ;;
      Exec) [[ -z "$exec_line" ]] && exec_line="$value" ;;
      TryExec) [[ -z "$tryexec" ]] && tryexec="$value" ;;
      StartupWMClass) [[ -z "$wmclass" ]] && wmclass="$value" ;;
    esac
  done < "$file"

  [[ -n "$exec_line" ]] || return 1
  printf '%s\t%s\t%s\t%s\t%s\n' "$exec_line" "$tryexec" "$name" "$name_l10n" "$wmclass"
}

desktop_score() {
  local file="$1" query="$2" parsed="$3" id exec_line tryexec name name_l10n wmclass exec_word exec_base score=0
  id="$(desktop_id "$file")"
  IFS=$'\t' read -r exec_line tryexec name name_l10n wmclass <<< "$parsed"
  exec_word="$(first_exec_word "$exec_line" 2>/dev/null || true)"
  exec_base="${exec_word##*/}"

  same_token "$id" "$query" && ((score += 150))
  [[ -n "$name" ]] && same_token "$name" "$query" && ((score += 140))
  [[ -n "$name_l10n" ]] && same_token "$name_l10n" "$query" && ((score += 140))
  [[ -n "$exec_base" ]] && same_token "$exec_base" "$query" && ((score += 150))
  [[ -n "$tryexec" ]] && same_token "${tryexec##*/}" "$query" && ((score += 130))
  [[ -n "$wmclass" ]] && same_token "$wmclass" "$query" && ((score += 120))

  if (( ${#query} >= 4 )); then
    contains_token "$id" "$query" && ((score += 25))
    [[ -n "$name" ]] && contains_token "$name" "$query" && ((score += 30))
    [[ -n "$name_l10n" ]] && contains_token "$name_l10n" "$query" && ((score += 30))
    [[ -n "$exec_base" ]] && contains_token "$exec_base" "$query" && ((score += 25))
  fi

  printf '%s' "$score"
}

desktop_result() {
  local file="$1" parsed="$2" exec_line tryexec name name_l10n wmclass exec_word resolved wrapper names
  IFS=$'\t' read -r exec_line tryexec name name_l10n wmclass <<< "$parsed"
  exec_word="$(first_exec_word "$exec_line" 2>/dev/null || true)"
  [[ -n "$exec_word" ]] || return 1

  resolved="$(resolve_exec_path "$exec_word")"
  wrapper="$(resolve_wrapper_exec_path "$resolved" 2>/dev/null || true)"
  [[ -n "$wrapper" ]] && resolved="$wrapper"

  names="$name"
  [[ -n "$name_l10n" ]] && names+="|$name_l10n"
  [[ -n "$wmclass" ]] && names+="|$wmclass"
  names+="|$(desktop_id "$file")|${exec_word##*/}|${resolved##*/}"

  printf '%s\t%s\n' "$resolved" "$names"
}

desktop_by_exact_id() {
  local query="$1" dir file parsed
  while IFS= read -r dir; do
    [[ -d "$dir" ]] || continue
    for file in "$dir/$query.desktop" "$dir/${query,,}.desktop"; do
      [[ -f "$file" ]] || continue
      parsed="$(parse_desktop "$file" 2>/dev/null || true)"
      [[ -n "$parsed" ]] || continue
      desktop_result "$file" "$parsed"
      return 0
    done
  done < <(desktop_dirs)
  return 1
}

desktop_by_scan() {
  local query="$1" dir file parsed score best_score=0 best_file="" best_parsed=""
  shopt -s nullglob
  while IFS= read -r dir; do
    [[ -d "$dir" ]] || continue
    for file in "$dir"/*.desktop; do
      parsed="$(parse_desktop "$file" 2>/dev/null || true)"
      [[ -n "$parsed" ]] || continue
      score="$(desktop_score "$file" "$query" "$parsed")"
      (( score > best_score )) || continue
      best_score="$score"
      best_file="$file"
      best_parsed="$parsed"
    done
  done < <(desktop_dirs)
  shopt -u nullglob

  (( best_score >= 80 )) || return 1
  desktop_result "$best_file" "$best_parsed"
}

command_target() {
  local query="$1" resolved wrapper
  resolved="$(resolve_exec_path "$query")"
  [[ "$resolved" != "$query" || "$query" == */* ]] || return 1
  wrapper="$(resolve_wrapper_exec_path "$resolved" 2>/dev/null || true)"
  [[ -n "$wrapper" ]] && resolved="$wrapper"
  printf '%s\t%s\n' "$resolved" "${query##*/}|${resolved##*/}"
}

find_app_target() {
  local query="$1"
  desktop_by_exact_id "$query" && return 0
  command_target "$query" && return 0
  desktop_by_scan "$query" && return 0
  return 1
}

looks_like_helper() {
  local text=" ${1,,} "
  [[ "$text" == *' --type='* ]] && return 0
  [[ "$text" == *' helper'* ]] && return 0
  [[ "$text" == *' renderer'* ]] && return 0
  [[ "$text" == *' zygote'* ]] && return 0
  [[ "$text" == *' gpu-process'* ]] && return 0
  [[ "$text" == *' utility'* ]] && return 0
  [[ "$text" == *' crashpad'* ]] && return 0
  [[ "$text" == *' crashhandler'* ]] && return 0
  [[ "$text" == *' sandbox'* ]] && return 0
  [[ "$text" == *' serverworkermain'* ]] && return 0
  [[ "$text" == *' extensionhost'* ]] && return 0
  [[ "$text" == *' extension-process'* ]] && return 0
  [[ "$text" == *' -contentproc'* ]] && return 0
  [[ "$text" == *' childID='* ]] && return 0
  return 1
}

candidate_score() {
  local query="$1" expected_exec="$2" expected_base="$3" names="$4" pid="$5" comm="$6" argv0="$7" cmd="$8"
  local score=0 name exe_path exe_base

  if [[ -n "$expected_base" ]]; then
    same_token "$comm" "$expected_base" && ((score += 220))
    same_token "$argv0" "$expected_base" && ((score += 220))
  fi

  same_token "$comm" "$query" && ((score += 200))
  same_token "$argv0" "$query" && ((score += 200))

  IFS='|' read -r -a name_parts <<< "$names"
  for name in "${name_parts[@]}"; do
    name="$(trim "$name")"
    [[ -n "$name" ]] || continue
    same_token "$comm" "$name" && ((score += 170))
    same_token "$argv0" "$name" && ((score += 170))
  done

  if (( score > 0 )) && [[ -n "$expected_exec" ]]; then
    exe_path="$(read_exe_path "$pid" 2>/dev/null || true)"
    exe_base="${exe_path##*/}"
    [[ -n "$exe_path" && "$exe_path" == "$expected_exec" ]] && ((score += 260))
    [[ -n "$exe_base" ]] && same_token "$exe_base" "$expected_base" && ((score += 120))
  fi

  if (( score == 0 && ${#query} >= 4 )); then
    contains_token "$comm" "$query" && ((score += 35))
    contains_token "$argv0" "$query" && ((score += 35))
  fi

  looks_like_helper "$cmd $comm $argv0" && ((score -= 320))

  case "$comm" in
    bash|sh|zsh|fish|env|systemd|sudo|su|nohup|setsid|grep|pgrep|awk|sed|sort|find)
      ((score -= 100))
      ;;
  esac

  printf '%s' "$score"
}

collect_candidates() {
  local query="$1" expected_exec="$2" names="$3" expected_base="$4"
  local proc pid comm argv0 cmd score pattern seen="" fast_pids=""

  add_fast_candidates() {
    local pattern="$1" pid
    [[ -n "$pattern" ]] || return 0
    pgrep -x -- "$pattern" 2>/dev/null | while IFS= read -r pid; do
      [[ -n "$pid" && -d "/proc/$pid" ]] || continue
      printf '%s\n' "$pid"
    done
  }

  while IFS= read -r pattern; do
    pattern="$(trim "$pattern")"
    [[ -n "$pattern" ]] || continue
    while IFS= read -r pid; do
      [[ -n "$pid" ]] || continue
      [[ "$fast_pids" == *" $pid "* ]] && continue
      fast_pids+=" $pid "
    done < <(add_fast_candidates "$pattern")
  done < <(
    printf '%s\n' "$query"
    [[ -n "$expected_base" ]] && printf '%s\n' "$expected_base"
    IFS='|' read -r -a name_parts <<< "$names"
    for pattern in "${name_parts[@]}"; do
      printf '%s\n' "$pattern"
    done
  )

  for pid in $fast_pids; do
    [[ -n "$pid" && -d "/proc/$pid" ]] || continue
    [[ "$pid" == "$$" || "$pid" == "$PPID" ]] && continue
    [[ "$seen" == *"|$pid|"* ]] && continue
    seen="${seen}|${pid}|"

    comm="$(read_comm "$pid" 2>/dev/null || true)"
    [[ -n "$comm" ]] || continue
    argv0="$(read_argv0 "$pid" 2>/dev/null || true)"
    [[ -n "$argv0" ]] || continue
    cmd="$(read_cmdline "$pid" 2>/dev/null || true)"
    [[ -n "$cmd" ]] || continue
    [[ "$cmd" == *"$APP_NAME"* ]] && continue

    score="$(candidate_score "$query" "$expected_exec" "$expected_base" "$names" "$pid" "$comm" "$argv0" "$cmd")"
    printf '%s\t%s\t%s\t%s\n' "$score" "$pid" "$(read_ppid "$pid" 2>/dev/null || true)" "$cmd"
  done

  # The fast path is enough for normal desktop apps. Fall back to a broader
  # /proc scan only when no exact comm candidate exists, which preserves fuzzy
  # matching without slowing down common calls.
  [[ -n "$fast_pids" ]] && return 0

  for proc in /proc/[0-9]*; do
    [[ -d "$proc" ]] || continue
    pid="${proc##*/}"
    [[ "$pid" == "$$" || "$pid" == "$PPID" ]] && continue

    comm="$(read_comm "$pid" 2>/dev/null || true)"
    [[ -n "$comm" ]] || continue
    argv0="$(read_argv0 "$pid" 2>/dev/null || true)"
    [[ -n "$argv0" ]] || continue

    if [[ -n "$expected_base" ]]; then
      same_token "$comm" "$expected_base" || same_token "$argv0" "$expected_base" || same_token "$comm" "$query" || same_token "$argv0" "$query" || continue
    elif (( ${#query} < 4 )); then
      same_token "$comm" "$query" || same_token "$argv0" "$query" || continue
    else
      same_token "$comm" "$query" || same_token "$argv0" "$query" || contains_token "$comm" "$query" || contains_token "$argv0" "$query" || continue
    fi

    cmd="$(read_cmdline "$pid" 2>/dev/null || true)"
    [[ -n "$cmd" ]] || continue
    [[ "$cmd" == *"$APP_NAME"* ]] && continue

    score="$(candidate_score "$query" "$expected_exec" "$expected_base" "$names" "$pid" "$comm" "$argv0" "$cmd")"
    printf '%s\t%s\t%s\t%s\n' "$score" "$pid" "$(read_ppid "$pid" 2>/dev/null || true)" "$cmd"
  done
}

select_pid() {
  local query="$1" expected_exec="$2" names="$3" expected_base="$4"
  local rows adjusted_rows all_pids score pid ppid cmd other best_score="" best_pid="" best_cmd="" ties=0 bonus

  rows="$(collect_candidates "$query" "$expected_exec" "$names" "$expected_base")"
  [[ -n "$rows" ]] || return 1
  all_pids="$(printf '%s\n' "$rows" | while IFS=$'\t' read -r _ pid _ _; do printf ' %s ' "$pid"; done)"

  adjusted_rows=""
  while IFS=$'\t' read -r score pid ppid cmd; do
    [[ -n "$score" && -n "$pid" ]] || continue
    bonus=0
    while IFS=$'\t' read -r _ other other_ppid _; do
      [[ "$other" != "$pid" && "$other_ppid" == "$pid" ]] && bonus=40 && break
    done <<< "$rows"
    adjusted_rows+="$((score + bonus))"$'\t'"$pid"$'\t'"$cmd"$'\n'
  done <<< "$rows"

  adjusted_rows="$(printf '%s' "$adjusted_rows" | sort -rn -k1,1 -k2,2)"
  while IFS=$'\t' read -r score pid cmd; do
    [[ -n "$score" && -n "$pid" ]] || continue
    if [[ -z "$best_score" ]]; then
      best_score="$score"
      best_pid="$pid"
      best_cmd="$cmd"
      ties=1
    elif [[ "$score" == "$best_score" ]]; then
      ((ties += 1))
    fi
  done <<< "$adjusted_rows"

  [[ -n "$best_pid" ]] || return 1

  if (( best_score < 100 )); then
    printf 'Matched processes for "%s", but none looks like the main app process:\n\n' "$query" >&2
    printf '%s\n' "$adjusted_rows" | awk -F '\t' '{ printf "  PID %-8s score %-4s %s\n", $2, $1, $3 }' >&2
    return 2
  fi

  if (( ties > 1 )); then
    printf 'Multiple likely processes matched "%s". Choose one with --pid:\n\n' "$query" >&2
    printf '%s\n' "$adjusted_rows" | awk -v best="$best_score" -F '\t' '$1 == best { printf "  PID %-8s score %-4s %s\n", $2, $1, $3 }' >&2
    return 2
  fi

  printf '%s\t%s\n' "$best_pid" "$best_cmd"
}

print_env() {
  local pid="$1" cmd="${2:-}" entry
  [[ -d "/proc/$pid" ]] || die "process $pid does not exist"
  [[ -r "/proc/$pid/environ" ]] || die "cannot read /proc/$pid/environ; try running with sufficient permission"

  [[ -n "$cmd" ]] || cmd="$(read_cmdline "$pid" 2>/dev/null || true)"

  printf 'PID: %s\n' "$pid"
  [[ -n "$cmd" ]] && printf 'Command: %s\n' "$cmd"
  printf '\nEnvironment:\n'
  while IFS= read -r -d '' entry; do
    printf '%s\n' "$entry"
  done < "/proc/$pid/environ" | sort
}

main() {
  local target pid app_target expected_exec names expected_base selected cmd

  if [[ $# -eq 0 && ! -t 0 ]]; then
    target="$(target_from_input "$(cat)" 2>/dev/null || true)"
    [[ -n "$target" ]] && set -- "$target"
  fi

  case "${1:-}" in
    -h|--help|'')
      usage
      [[ "${1:-}" == "" ]] && exit 1 || exit 0
      ;;
    --pid)
      pid="${2:-}"
      is_pid "$pid" || die "--pid requires a numeric PID"
      print_env "$pid"
      exit 0
      ;;
  esac

  target="$1"
  if is_pid "$target"; then
    print_env "$target"
    exit 0
  fi

  app_target="$(find_app_target "$target" 2>/dev/null || true)"
  if [[ -n "$app_target" ]]; then
    expected_exec="${app_target%%$'\t'*}"
    names="${app_target#*$'\t'}"
    expected_base="${expected_exec##*/}"
  else
    expected_exec=""
    names="$target"
    expected_base=""
  fi

  selected="$(select_pid "$target" "$expected_exec" "$names" "$expected_base")" || {
    case "$?" in
      1) die "no running process found for '$target'" ;;
      2) die "ambiguous process match; rerun with --pid <pid>" ;;
      *) die "failed to select process for '$target'" ;;
    esac
  }

  pid="${selected%%$'\t'*}"
  cmd="${selected#*$'\t'}"
  print_env "$pid" "$cmd"
}

main "$@"
